.wp-env.override.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage directory used by tools like istanbul
coverage

# Build output (only at root)
/build/
/websocket-server/dist/

# Dependency directories
/node_modules/
/vendor/
/websocket-server/node_modules/
/yjs-inspector/node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Tests
.phpunit.cache/
.phpunit.result.cache
/artifacts/

# Output of `npm run plugin-zip`
*.zip

# Editors
.idea/*
!.idea/runConfigurations/
.vscode/*
!.vscode/launch.json
.zed
