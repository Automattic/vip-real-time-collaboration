{
  "name": "vip-real-time-collaboration",
  "version": "0.1.0",
  "description": "Real-time collaboration plugin for WordPress VIP",
  "main": "build/index.js",
  "keywords": [
    "wordpress",
    "plugin",
    "real-time",
    "collaboration",
    "vip"
  ],
  "files": [
    "build/",
    "inc/",
    "vendor/",
    "vip-real-time-collaboration.php"
  ],
  "author": "Automattic",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "build": "npm run cmd:build",
    "check-types": "tsc --noEmit",
    "cmd:build": "wp-scripts build --experimental-modules",
    "cmd:format": "prettier '**/*.(js|json|jsx|md|ts|tsx|yml|yaml)'",
    "cmd:lint:js": "eslint --ext 'js,jsx,ts,tsx' --quiet",
    "dev": "./bin/start",
    "dev:build": "./bin/start default build",
    "dev:destroy": "./bin/stop destroy",
    "dev:stop": "./bin/stop",
    "format": "npm run cmd:format -- --write",
    "format:check": "npm run cmd:format -- --check",
    "lint": "npm run format:check && npm run lint:js && npm run lint:css && npm run lint:php",
    "lint:css": "echo 'No CSS files have been committed yet.' # wp-scripts lint-style",
    "lint:css:fix": "wp-scripts lint-style --fix",
    "lint:js": "npm run cmd:lint:js",
    "lint:js:fix": "npm run cmd:lint:js . -- --fix",
    "lint:php": "npm run lint:phpcs && npm run lint:psalm",
    "lint:phpcs": "vendor/bin/phpcs --cache",
    "lint:phpcs:fix": "vendor/bin/phpcbf",
    "lint:psalm": "vendor/bin/psalm.phar",
    "packages-update": "wp-scripts packages-update",
    "plugin-zip": "npm run build && composer install --prefer-dist --optimize-autoloader --no-dev && wp-scripts plugin-zip",
    "postinstall": "composer install",
    "release": "./bin/release",
    "start": "wp-scripts start --experimental-modules --stats=minimal",
    "start:websocket-server": "npx --yes tsx websocket-server",
    "test:e2e": "wp-scripts test-playwright --config tests/e2e/playwright.config.ts",
    "test:e2e:debug": "wp-scripts test-playwright --config tests/e2e/playwright.config.ts --ui",
    "wp-cli": "wp-env run cli -- wp"
  },
  "devDependencies": {
    "@automattic/eslint-plugin-wpvip": "0.13.1",
    "@playwright/test": "^1.54.1",
    "@types/jsonwebtoken": "9.0.10",
    "@wordpress/api-fetch": "7.27.0",
    "@wordpress/core-data": "7.27.0",
    "@wordpress/e2e-test-utils-playwright": "^1.26.0",
    "@wordpress/env": "10.25.0",
    "@wordpress/hooks": "4.25.0",
    "@wordpress/i18n": "6.0.0",
    "@wordpress/scripts": "30.1.0",
    "@wordpress/sync": "1.27.0",
    "@y/websocket-server": "0.1.1",
    "eslint": "8.57.1",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "husky": "9.1.7",
    "jsonwebtoken": "9.0.2",
    "lint-staged": "16.1.0",
    "prettier": "npm:wp-prettier@2.8.5",
    "ts-loader": "9.5.2",
    "typescript": "5.8.3",
    "ws": "8.18.2",
    "yjs": "13.6.27"
  },
  "dependencies": {
    "lib0": "^0.2.114",
    "y-protocols": "1.0.6",
    "y-websocket": "^3.0.0"
  }
}
