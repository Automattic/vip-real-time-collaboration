#!/bin/sh

set -e # Exit immediately if any command exits with a non-zero status.

# Set WordPress port and home URL.
PORT="${WP_ENV_PORT-8888}"
METRICS_PORT="${METRICS_PORT-9090}"
WP_HOME="${WP_ENV_HOME_URL-http://localhost:$PORT}"
WS_PORT="${WS_PORT-1234}"
YJS_INSPECTOR_PORT="${YJS_INSPECTOR_PORT-5173}"

cleanup() {
    echo ""
    echo "✊ Caught SIG signal. Stopping all development builds..."

    # Kill any lingering Node.js processes.
    pkill -f 'vip-real-time-collaboration/node_modules/'
    pkill -f 'vip-real-time-collaboration/websocket-server/node_modules'
    pkill -f 'vip-real-time-collaboration/yjs-inspector/node_modules'

    printf "Stop WordPress? (y/n) "
    read -r answer
    if [ "$answer" != "${answer#[Yy]}" ]; then
        npm run -s dev:stop
    fi

    exit 0
}

activate_plugin() {
    slug="$1"

    if (npm run -s wp-cli plugin is-active "$slug" 2>/dev/null); then
        echo "✏️ $slug is already active."
    else
        echo "✏️ Activating $slug..."
        npm run -s wp-cli plugin activate "$slug"
    fi
}

deactivate_plugin() {
    slug="$1"

    if (npm run -s wp-cli plugin is-active "$slug" 2>/dev/null); then
        echo "✏️ Deactivating $slug..."
        npm run -s wp-cli plugin deactivate "$slug"
    fi
}

install_and_activate_plugin() {
    plugin="$1"
    slug="$2"

    if (npm run -s wp-cli plugin is-installed "$slug" 2>/dev/null); then
        echo "✏️ $slug is already installed."
    else
        echo "✏️ Installing $slug..."
        npm run -s wp-cli plugin install "$plugin"
    fi

    activate_plugin "$slug"
}

configure_wordpress() {
    echo "✏️ Updating home option..."
    npm run -s wp-cli config set WP_HOME "$WP_HOME"
}

install_dependencies() {
    if [ ! -d "vendor" ]; then
        echo "🏗️ Installing PHP dependencies..."
        composer install --no-interaction --optimize-autoloader
    fi

    if [ ! -d "node_modules" ]; then
        echo "🏗️ Installing Node.js dependencies..."
        npm install --no-audit --no-fund
    fi

    if [ ! -d "websocket-server/node_modules" ]; then
        echo "🏗️ Installing WebSocket server dependencies..."
        cd websocket-server && npm install --no-audit --no-fund
        cd -
    fi

    if [ ! -d "yjs-inspector/node_modules" ]; then
        echo "🏗️ Installing Yjs inspector dependencies..."
        cd yjs-inspector && npm install --legacy-peer-deps --no-audit --no-fund
        cd -
    fi
}

start_websocket_server() {
    echo "🔼 Starting WebSocket server development build..."
    VIP_RTC_WS_AUTH_SECRET=vip_rtc_ws_auth_secret METRICS_PORT=$METRICS_PORT PORT=$WS_PORT npm run -s dev:websocket-server &
}

start_yjs_inspector() {
    echo "🔼 Starting Yjs Inspector development build..."
    VITE_PORT=$YJS_INSPECTOR_PORT npm run -s dev:yjs-inspector &
}

start_wordpress() {
    # Enable Xdebug when starting the server in "start" mode.
    FLAGS=""
    if [ "$SCRIPT_MODE" = "start" ]; then
        FLAGS="${WP_ENV_FLAGS---xdebug}"
    fi

    echo "🔼 Starting WordPress..."
    WP_ENV_PORT="$PORT" npx wp-env start "$FLAGS"
}

open_browser() {
    WP_ADMIN_URL="http://localhost:$PORT/wp-admin/"
    WS_SERVER_URL="ws://localhost:$WS_PORT/"
    YJS_INSPECTOR_URL="http://localhost:$YJS_INSPECTOR_PORT/"

    echo ""
    echo "> 🌐 WordPress Admin: $WP_ADMIN_URL"
    echo "> 🔑 Username: admin"
    echo "> 🔑 Password: password"
    echo ""
    echo "> 🔍 WebSocket server: $WS_SERVER_URL"
    echo "> 🔍 Yjs Inspector: $YJS_INSPECTOR_URL"
    echo ""

    # Opening the browser is disruptive, make users opt-in.
    if [ -z "$WP_ENV_OPEN_BROWSER" ]; then
        return
    fi

    UNAME="$(uname -s)"

    if [ "Darwin" = "$UNAME" ]; then
        open "$WP_ADMIN_URL"
    elif [ "Linux" = "$UNAME" ]; then
        xdg-open "$WP_ADMIN_URL"
    fi
}

# Cleanup after error or trapping SIGINT (Ctrl+C) and SIGTERM signals
trap 'cleanup' INT TERM

install_dependencies
start_websocket_server
start_yjs_inspector
start_wordpress
configure_wordpress

open_browser

# Start wp-scripts development build
echo "🔼 Starting plugin scripts development build..."
npm start
