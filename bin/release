#!/bin/sh

# Function to increment version
increment_version() {
    version=$1
    release=$2

    major=$(echo "$version" | cut -d. -f1)
    minor=$(echo "$version" | cut -d. -f2)
    patch=$(echo "$version" | cut -d. -f3)

    case $release in
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        patch)
            patch=$((patch + 1))
            ;;
        *)
            echo "Invalid release type. Use 'major', 'minor', or 'patch'."
            exit 1
            ;;
    esac

    echo "${major}.${minor}.${patch}"
}

# Check if an argument is provided
if [ $# -eq 0 ]; then
    echo "Please provide a release type: major, minor, or patch"
    exit 1
fi

release_type=$1

# Get current version from vip-real-time-collaboration.php
php_file="vip-real-time-collaboration.php"
current_version=$(sed -n "s/.*Version: \([0-9.]*\).*/\1/p" "$php_file")
new_version=$(increment_version "$current_version" "$release_type")

# Update vip-real-time-collaboration.php
sed -i.bak "s/Version: $current_version/Version: $new_version/" "$php_file"
sed -i.bak "s/define( 'VIP_REAL_TIME_COLLABORATION__PLUGIN_VERSION', '$current_version' );/define( 'VIP_REAL_TIME_COLLABORATION__PLUGIN_VERSION', '$new_version' );/" "$php_file"
rm "${php_file}.bak"

echo "Updated $php_file from $current_version to $new_version"

# Get current version from package.json
package_file="package.json"
package_lock_file="package-lock.json"
current_version_pkg=$(sed -n 's/.*"version": "\([0-9.]*\)".*/\1/p' "$package_file")

# Update package.json
sed -i.bak "s/\"version\": \"$current_version_pkg\"/\"version\": \"$new_version\"/" "$package_file"
rm "${package_file}.bak"

echo "Updated $package_file from $current_version_pkg to $new_version"

echo "Version bump complete: $new_version"

# Update package-lock.json
npm install

echo "Updated package-lock.json with new version."

# Create a new branch for the release
git checkout -b release/v"$new_version"

# Commit the changes
git add "$php_file"
git add "$package_file"
git add "$package_lock_file"
git commit -m "v$new_version"

echo "Changes committed to release/v$new_version branch. Push the branch to the remote repository and create a pull request."
